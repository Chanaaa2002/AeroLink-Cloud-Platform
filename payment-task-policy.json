{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PaymentsTableAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:DescribeTable",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Scan",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:668855907287:table/PaymentsTable"
      ]
    },
    {
      "Sid": "PublishPaymentEvents",
      "Effect": "Allow",
      "Action": [
        "events:PutEvents"
      ],
      "Resource": [
        "arn:aws:events:us-east-1:668855907287:event-bus/AeroLinkEventBus"
      ]
    }
  ]
}
