            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{staffToken}}", "type": "string" } ] },
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": "{{baseUrl}}/notifications/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Staff token is rejected by passenger-only notifications endpoint', function () { pm.expect(pm.response.code).to.equal(403); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
