{
  "info": {
    "name": "AeroLink Hosted API",
    "description": "Postman collection for the deployed AeroLink Cloud Platform hosted on AWS API Gateway. It uses environment variables only and avoids embedding real tokens, secrets, or payment credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health / Public",
      "item": [
        {
          "name": "GET /health (optional)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function parseJsonSafe() {",
                  "  try { return pm.response.json(); } catch (error) { return null; }",
                  "}",
                  "const body = parseJsonSafe();",
                  "pm.test('Health endpoint is optional', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Health response is JSON when available', function () {",
                  "    pm.expect(body, 'Expected JSON response body').to.not.equal(null);",
                  "  });",
                  "  pm.test('Health response contains service and status when available', function () {",
                  "    pm.expect(body).to.have.property('service');",
                  "    pm.expect(body).to.have.property('status');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /flights",
