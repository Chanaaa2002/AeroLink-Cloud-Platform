    {
      "name": "Passenger Booking Flow",
      "item": [
        {
          "name": "POST /bookings",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{passengerToken}}", "type": "string" } ] },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": \"{{flightId}}\",\n  \"passengerName\": \"{{testPassengerName}}\",\n  \"seatCount\": {{seatCount}}\n}"
            },
            "url": "{{baseUrl}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function parseJsonSafe() {",
                  "  try { return pm.response.json(); } catch (error) { return null; }",
                  "}",
                  "const body = parseJsonSafe();",
                  "const currentBookingId = body && body.bookingId ? body.bookingId : null;",
                  "pm.test('Status is 200 or 201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "pm.test('Response is JSON', function () { pm.expect(body, 'Expected JSON response body').to.not.equal(null); });",
                  "pm.test('Created booking has bookingId', function () {",
                  "  pm.expect(body).to.have.property('bookingId');",
                  "  pm.expect(body.bookingId, 'bookingId should not be empty').to.be.a('string').and.not.be.empty;",
                  "});",
                  "pm.test('Created booking has expected initial status', function () {",
                  "  if (body && body.bookingStatus) { pm.expect(['PENDING_PAYMENT', 'PENDING']).to.include(body.bookingStatus); }",
                  "});",
                  "pm.test('Seat count is present', function () {",
                  "  if (body && typeof body.seatCount !== 'undefined') { pm.expect(body.seatCount).to.equal(Number(pm.environment.get('seatCount'))); }",
                  "});",
                  "if (currentBookingId) { pm.environment.set('bookingId', currentBookingId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /bookings/me",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{passengerToken}}", "type": "string" } ] },
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": "{{baseUrl}}/bookings/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function parseJsonSafe() {",
                  "  try { return pm.response.json(); } catch (error) { return null; }",
                  "}",
                  "const body = parseJsonSafe();",
                  "const savedBookingId = pm.environment.get('bookingId');",
                  "pm.test('Status is 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Response is JSON', function () { pm.expect(body, 'Expected JSON response body').to.not.equal(null); });",
                  "pm.test('Passenger bookings response is an array', function () { pm.expect(Array.isArray(body)).to.be.true; });",
                  "pm.test('Passenger booking list includes the created booking when available', function () {",
                  "  if (Array.isArray(body) && savedBookingId) {",
                  "    pm.expect(body.some(function (item) { return item.bookingId === savedBookingId; })).to.be.true;",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
