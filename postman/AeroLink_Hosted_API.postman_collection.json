            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function parseJsonSafe() {",
                  "  try { return pm.response.json(); } catch (error) { return null; }",
                  "}",
                  "const body = parseJsonSafe();",
                  "pm.test('Status is 200 or 201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "pm.test('Response is JSON', function () { pm.expect(body, 'Expected JSON response body').to.not.equal(null); });",
                  "pm.test('Checkout session includes checkout URL', function () {",
                  "  pm.expect(body).to.satisfy(function (value) { return !!(value && (value.checkoutUrl || value.url)); });",
                  "});",
