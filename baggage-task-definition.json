{
  "family": "aerolink-baggage-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::668855907287:role/aerolink-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::668855907287:role/aerolink-baggage-task-role",
  "containerDefinitions": [
    {
      "name": "aerolink-baggage-service",
      "image": "668855907287.dkr.ecr.us-east-1.amazonaws.com/aerolink-baggage-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8083,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "AWS_DEFAULT_REGION",
          "value": "us-east-1"
        },
        {
          "name": "SERVICES_BOOKING_BASE_URL",
          "value": "http://aerolink-alb-1937371221.us-east-1.elb.amazonaws.com"
        },
        {
          "name": "AWS_EVENTBRIDGE_BUS_NAME",
          "value": "AeroLinkEventBus"
        },
        {
          "name": "AWS_EVENTBRIDGE_REGION",
          "value": "us-east-1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aerolink-baggage-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
